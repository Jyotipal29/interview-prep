# ─── LLM Providers ────────────────────────────────────────────────────────────
# Set the provider to use: openai | anthropic | openrouter
LLM_PROVIDER=openai

# Model name (provider-specific, e.g. gpt-4o, claude-3-5-sonnet-20241022)
LLM_MODEL=gpt-4o

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.0

# ─── API Keys ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# ─── Search & Crawl ───────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-...
EXA_API_KEY=...
FIRECRAWL_API_KEY=fc-...

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string for LangGraph checkpointing.
# Leave unset to use in-memory checkpointing (no persistence).
# DATABASE_URL=postgresql://user:password@localhost:5432/research_agent
